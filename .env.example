# Firebase Admin SDK — server only
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Firebase web application — public identifiers used only for administrator login
FIREBASE_WEB_API_KEY=replace-me
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
FIREBASE_APP_ID=1:000000000000:web:replace-me
FIREBASE_MESSAGING_SENDER_ID=000000000000

# Access control
ADMIN_EMAILS=khaled.alassad@syrianrenewables.com
ADMIN_REQUIRE_EMAIL_VERIFIED=true
APP_ORIGINS=https://ev.syrianrenewables.com,https://syr-ev-charger-map.vercel.app

# Data continuity and first-run migration
FIREBASE_AUTO_SEED_FROM_JSON=true
FIREBASE_FALLBACK_TO_JSON=true
