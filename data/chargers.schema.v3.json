{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syrianrenewables.com/schemas/ev-charger-v3.json",
  "title": "Syrian Renewables EV Charger Record",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "suggested_id",
    "company_ar",
    "company_en",
    "governorate_ar",
    "governorate_en",
    "city_ar",
    "city_en",
    "site_name_ar",
    "site_name_en",
    "charger_type_ar",
    "charger_type_en",
    "charger_numbers",
    "site_type_ar",
    "site_type_en",
    "google_maps_url",
    "latitude",
    "longitude"
  ],
  "properties": {
    "suggested_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{2,89}$" },
    "company_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "company_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "governorate_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "governorate_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "city_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "city_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "site_name_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "site_name_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "charger_type_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "charger_type_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "charger_numbers": { "type": "integer", "minimum": 1, "maximum": 200 },
    "site_type_ar": { "type": "string", "minLength": 1, "maxLength": 180 },
    "site_type_en": { "type": "string", "minLength": 1, "maxLength": 180 },
    "google_maps_url": { "type": "string", "format": "uri", "maxLength": 700 },
    "latitude": { "type": "number", "minimum": 32, "maximum": 38 },
    "longitude": { "type": "number", "minimum": 35, "maximum": 43 },
    "published": { "type": "boolean", "default": true },
    "status": { "type": "string", "default": "listed" },
    "data_quality": { "type": "string", "default": "Medium Confidence" }
  }
}
